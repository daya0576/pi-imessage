{
	"name": "pi-imessage",
	"version": "0.0.1",
	"private": true,
	"type": "module",
	"engines": {
		"node": ">=20.0.0"
	},
	"scripts": {
		"build": "tsc",
		"dev": "tsx watch src/main.ts",
		"start": "tsx src/main.ts",
		"test": "vitest run",
		"typecheck": "tsc --noEmit",
		"lint": "biome check .",
		"format": "biome format --write .",
		"check": "tsc --noEmit && biome check ."
	},
	"dependencies": {
		"@mariozechner/pi-agent-core": "latest",
		"@mariozechner/pi-ai": "latest",
		"@mariozechner/pi-coding-agent": "latest",
		"dotenv": "^17.3.1",
		"eta": "^4.5.1"
	},
	"devDependencies": {
		"@biomejs/biome": "^1.9.4",
		"@types/node": "^22.0.0",
		"@vitest/coverage-v8": "^3.2.4",
		"tsx": "^4.0.0",
		"typescript": "^5.7.3",
		"vitest": "^3.0.0"
	}
}
