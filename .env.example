# BlueBubbles server (required)
BLUEBUBBLES_URL=http://localhost:1234
BLUEBUBBLES_PASSWORD=

# Blue server (optional)
BLUE_PORT=7749

# Working directory for session persistence.
# Each iMessage chat gets its own subfolder: <WORKING_DIR>/<chatGuid>/context.jsonl
# Defaults to ./data relative to the project root.
WORKING_DIR=./data
