<!DOCTYPE html>
<html><head><meta charset="UTF-8"><title>blue — logs</title>
<style>
* { margin: 0; padding: 0 }
body { background: #111; color: #ccc; font: 13px/1.6 monospace; display: flex; height: 100vh; overflow: hidden }
nav { width: 100px; flex-shrink: 0; padding: 40px 16px; border-right: 1px solid #1a1a1a }
nav a { display: block; color: inherit; text-decoration: none; line-height: 2.4; opacity: .35 }
nav a:hover, nav a.active { opacity: 1 }
.content { flex: 1; display: flex; flex-direction: column; gap: 16px; padding: 40px; overflow: hidden }
.card { flex: 1; background: #1a1a1a; display: flex; flex-direction: column; overflow: hidden; min-height: 0 }
.card-header { padding: 8px 16px; opacity: .4; flex-shrink: 0; border-bottom: 1px solid #252525 }
.card-body { flex: 1; overflow-y: auto; padding: 12px 16px }
pre { white-space: pre-wrap; word-break: break-word; opacity: .7; margin: 0 }
</style></head><body>

<nav>
  <a href="/">Recent Chats</a>
  <a href="/logs" class="active">Logs</a>
  <a href="/memory">Memory</a>
</nav>

<div class="content">
  <div class="card">
    <div class="card-header">digest.log</div>
    <div class="card-body" id="digest-body">
      <pre id="digest-pre"><%= it.digestLog %></pre>
    </div>
  </div>
  <div class="card">
    <div class="card-header">app.log</div>
    <div class="card-body" id="app-body">
      <pre id="app-pre"><%= it.appLog %></pre>
    </div>
  </div>
</div>

<script>
function isAtBottom(el) {
  return el.scrollHeight - el.scrollTop - el.clientHeight < 20;
}

function initScroll() {
  document.getElementById('digest-body').scrollTop = document.getElementById('digest-body').scrollHeight;
  document.getElementById('app-body').scrollTop = document.getElementById('app-body').scrollHeight;
}

async function refreshLogs() {
  try {
    const resp = await fetch('/logs/data');
    const data = await resp.json();
    const pairs = [
      ['digest-pre', 'digest-body', data.digestLog],
      ['app-pre', 'app-body', data.appLog],
    ];
    for (const [preId, bodyId, text] of pairs) {
      const pre = document.getElementById(preId);
      const body = document.getElementById(bodyId);
      const wasAtBottom = isAtBottom(body);
      pre.textContent = text;
      if (wasAtBottom) body.scrollTop = body.scrollHeight;
    }
  } catch {}
}

initScroll();
const es = new EventSource('/events');
es.addEventListener('update', refreshLogs);
setInterval(refreshLogs, 3000);
</script>
</body></html>
